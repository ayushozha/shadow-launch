# Shadow Launch — environment template (v2 · GTM Strategy Simulator)
# Copy this file to `.env` and fill in values. NEVER commit the real `.env`.
# `.env` is gitignored; `.env.example` is tracked.

# ============================================================================
# DATABASE — Postgres 17.7 via direct TLS (no SSH tunnel required)
# Connection string format:
#   postgresql+asyncpg://<user>:<pw>@postgresql.ayushojha.com:5432/<db>?ssl=require
# Note: self-signed cert — use `ssl=require`, NOT `ssl=verify-full`.
# ============================================================================
DATABASE_URL=postgresql+asyncpg://admin:CHANGEME@postgresql.ayushojha.com:5432/shadowlaunch?ssl=require

# ============================================================================
# OpenAI — the primary LLM + image generator.
# Used by: Kalibr router (text) + campaign_generator (gpt-image-1).
# Get from: https://platform.openai.com/api-keys
# Key prefix: `sk-` or `sk-proj-` or `sk-svcacct-`
# ============================================================================
OPENAI_API_KEY=

# ============================================================================
# Kalibr — wraps every inter-agent LLM call for adaptive routing + cost/telemetry.
# Get from: https://dashboard.kalibr.systems (Settings → API Keys)
# Key prefix: `sk_`
# ============================================================================
KALIBR_API_KEY=
KALIBR_TENANT_ID=

# ============================================================================
# Apify — powers Stages 01 (product research), 02 (competitor discovery),
# 03 (social scraping), and 03.5 (market discourse). Verified actors in
# docs/apify-actors.md. Free-tier compatible.
# Get from: https://console.apify.com → Settings → Integrations
# Key prefix: `apify_api_`
# ============================================================================
APIFY_TOKEN=

# Cap per-actor memory so free-tier (8 GB total concurrency) fits a full run.
# Leave at 512 unless you have a paid plan with higher ceilings.
APIFY_ACTOR_MEMORY_MB=512

# ============================================================================
# Minds AI — 6 synthetic buyer personas for Stage 06 persona debate.
# Plan tier must be Premium or higher to create 6 sparks.
# Get from: https://getminds.ai/dashboard → Settings → API Keys
# Key prefix: `minds_`
# ============================================================================
MINDS_API_KEY=

# Set to `1` when your Minds plan supports 6 concurrent sparks AND you want
# the Round-2 cross-persona rebuttal step. Default `0` keeps round 1 only.
MINDS_ROUND_2=0

# ============================================================================
# Frontend ↔ Backend wiring
# The browser reads NEXT_PUBLIC_API_URL at build/load time to find the API.
# Default is fine for local dev. In production set to your deployed API URL.
# ============================================================================
NEXT_PUBLIC_API_URL=http://localhost:8000

# ============================================================================
# Optional — Anthropic as a hedge path. Not used in the default config
# (we're OpenAI-primary per the v2 pivot) but kept so Kalibr has a cross-
# provider fallback if you opt in.
# Get from: https://console.anthropic.com
# Key prefix: `sk-ant-`
# ============================================================================
ANTHROPIC_API_KEY=

# ============================================================================
# Windows only — prevents the Kalibr SDK's emoji startup banner from
# crashing on the default cp1252 console. Harmless on Linux/macOS.
# ============================================================================
PYTHONIOENCODING=utf-8
