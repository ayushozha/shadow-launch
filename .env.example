# Shadow Launch — environment template
# Copy this file to `.env` and fill in values. NEVER commit the real `.env`.
# `.env` is gitignored; `.env.example` is not.

# ---------------------------------------------------------------------------
# Kalibr — adaptive model routing (wraps every inter-agent LLM call)
# Get from: https://dashboard.kalibr.systems  (Settings → API Keys)
# Key prefix: `sk_`
# ---------------------------------------------------------------------------
KALIBR_API_KEY=
# Kalibr tenant identifier (usually `user_...` for individual accounts)
KALIBR_TENANT_ID=

# ---------------------------------------------------------------------------
# Anthropic — Claude Sonnet/Haiku powers Cartographer, Clerk facilitation,
# Scribe summary prose, and Kalibr's preferred path.
# Get from: https://console.anthropic.com  (Settings → API Keys)
# Key prefix: `sk-ant-`
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# OpenAI — fallback path for Kalibr when Claude is unavailable (optional
# but recommended so Kalibr has at least 2 candidate models per goal).
# Get from: https://platform.openai.com/api-keys
# Key prefix: `sk-`
# ---------------------------------------------------------------------------
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Apify — powers the Scout agent (Website Content Crawler, Google Search,
# Reddit, LinkedIn Jobs, G2/Capterra, Twitter/X — fan-out into market twin).
# Get from: https://console.apify.com  (Settings → Integrations → API token)
# Token prefix: `apify_api_`
# ---------------------------------------------------------------------------
APIFY_TOKEN=

# ---------------------------------------------------------------------------
# Minds AI — powers the Clerk agent (the 4-juror synthetic buyer panel).
# Get from: https://getminds.ai  (Settings → API Keys)
# Key prefix: `minds_`
# ---------------------------------------------------------------------------
MINDS_API_KEY=

# Live jury toggle. `0` = scaffold mode (cached transcript + Claude-authored
# reactions in Pixero-compatible schema). `1` = call the real Minds jury API
# (requires Premium plan or higher). Default `0`.
MINDS_LIVE=0

# ---------------------------------------------------------------------------
# Pixero — powers the Producer agent (5 Meta ad variants from winning wedge).
# Get from: the Pixero dashboard  (Account → API Keys)
# ---------------------------------------------------------------------------
PIXERO_API_KEY=

# ---------------------------------------------------------------------------
# Rory — powers the Scribe agent's launch-board export ("Open in Rory").
# Confirm access at the sponsor check-in table (key may be issued on-site).
# ---------------------------------------------------------------------------
RORY_API_KEY=

# ---------------------------------------------------------------------------
# Windows-only: force stdout/stderr to UTF-8 so trace events with em-dashes,
# smart quotes, etc. don't crash the orchestrator on `cp1252` terminals.
# Leave commented out on macOS/Linux.
# ---------------------------------------------------------------------------
# PYTHONIOENCODING=utf-8
